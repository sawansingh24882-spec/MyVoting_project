<html>

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #1d2671, #c33764);
            height: 100vh;
        }
    </style>
</head>

<body>

    <%- include('nav') %>

        <div class="container mt-5">

            <center>
                <div class="alert alert-danger d-flex align-items-center" role="alert">
                    <%=msg %>
                </div>
        </div>
        </center>
        <div class="row my-5">
            <div class="col-md-1"></div>
            <div class="col-md-2">
                <div class="card shadow p-0">
                    <h4 class="text-center">Voting Result</h4>
                    
                    <table class="table table-bordered table-striped table-hovoer table-dark">
                        <tr>
                            <td>Party</td>
                            <td>Vote</td>
                        </tr>
                        <% if (countvote.length> 0) { %>
                            <% countvote.forEach(row=>{ %>
                                <tr>
                                    <td>
                                        <%=row.party%>
                                    </td>
                                    <td>
                                        <%=row.totalvote%>
                                    </td>
                                </tr>

                                <% }) %>

                                    <% } else{ %>
                                        <tr>
                                            <td>no data found</td>
                                        </tr>
                                        <% } %>
                    </table>
                </div>
            </div>

            <!-- Party Section -->
            <div class="col-md-4">
                <div class="card shadow p-5">
                    <h4 class="text-center mb-3">Add/Remove Party</h4>
                    <form>
                        Enter Party
                        <input type="text" name="party" class="form-control">

                        <br>

                        <button class="btn btn-primary" type="submit" name="addParty" value="addParty">
                            Add Party
                        </button>

                        <button class="btn btn-danger" type="submit" name="removeParty" value="removeParty">
                            Remove Party
                        </button>

                    </form>

                </div>
            </div>


            <!-- Email Section -->
            <div class="col-md-4">
                <div class="card shadow p-2">

                    <h4 class="text-center">Add/Remove Voter</h4>

                    <form>

                        Enter Name
                        <input type="text" name="name" class="form-control">

                        <br>

                        Enter Email
                        <input type="text" name="email" class="form-control">

                        <br>

                        <button class="btn btn-primary" type="submit" name="addVoter" value="addVoter">
                            Add Voter
                        </button>

                        <button class="btn btn-danger" type="submit" name="removeVoter" value="removeVoter">
                            Remove Voter
                        </button>

                    </form>

                </div>
            </div>

        </div>

        </div>
        </div>

</body>

</html>