<html>

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #1d2671, #c33764);
            height: 100vh;
        }
    </style>
</head>

<body style="background-color:#f5f7fa;">

    <%- include('nav') %>
    

        <div class="container mt-5">

            <div class="text-center mb-4">
                <h2 class="fw-bold text-success">🗳️ Vote Now</h2>
                <p class="text-muted">Select your preferred party</p>
            </div>

            <div class="alert alert-danger d-flex align-items-center" role="alert">
                            <%=msg %>
                        </div>

            <!-- Card -->
            <div class="row justify-content-center">
                <div class="col-md-5">

                    <div class="card shadow-lg border-0 rounded-3">
                        <div class="card-body p-4">

                            <form method="post" action="/vote">


                                <div class="form-check mb-3 p-2 border rounded">
                                    <input class="form-check-input" type="radio" name="party" value="BJP" id="b">
                                    <label class="form-check-label fw-bold" for="b">
                                        BJP
                                    </label>
                                </div>


                                <div class="form-check mb-3 p-2 border rounded">
                                    <input class="form-check-input" type="radio" name="party" value="CONG" id="c">
                                    <label class="form-check-label fw-bold" for="c">
                                        CONG
                                    </label>
                                </div>


                                <div class="form-check mb-3 p-2 border rounded">
                                    <input class="form-check-input" type="radio" name="party" value="AAP" id="a">
                                    <label class="form-check-label fw-bold" for="a">
                                        AAP
                                    </label>
                                </div>


                                <div class="form-check mb-4 p-2 border rounded">
                                    <input class="form-check-input" type="radio" name="party" value="UKD" id="u">
                                    <label class="form-check-label fw-bold" for="u">
                                        UKD
                                    </label>
                                </div>


                                <div class="d-grid">
                                    <button class="btn btn-success btn-lg" type="submit" value="voted" name="voted">
                                        Submit Vote
                                    </button>
                                </div>

                            </form>

                        </div>
                    </div>

                </div>
            </div>

        </div>

</body>

</html>